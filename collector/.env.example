# Cron schedule (every minute by default).
CRON_SCHEDULE=* * * * *

# Path Deno KV opens. Leave unset to use the default in-memory/SQLite location.
# DENO_KV_PATH=./openblob.kv

# 0x-prefixed hex private key of the Sepolia account that publishes blob txs.
# When unset, the bundling cron logs the pending batch and skips sending so dev
# and CI keep working without funds.
# BUNDLER_PRIVATE_KEY=0x...

# Sepolia RPC URL used by the bundler. Defaults to https://sepolia.drpc.org.
# BUNDLER_RPC_URL=https://sepolia.drpc.org

# Optional `to` address for blob txs. Defaults to the sender's own address
# (self-send; blobs are addressed by versioned hash, not by `to`).
# BUNDLER_TO=0x...
